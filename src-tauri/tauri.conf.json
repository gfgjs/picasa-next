{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Picasa Next",
  "version": "0.1.0",
  "identifier": "com.picasanext.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Picasa Next",
        "width": 1280,
        "height": 820,
        "minWidth": 800,
        "minHeight": 560,
        "decorations": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "window-state": {
      "stateFlags": "all"
    },
    "fs": {
      "scope": ["$APPDATA/**", "$HOME/**", "$DESKTOP/**", "$DOWNLOAD/**", "$DOCUMENT/**", "$PICTURE/**", "$VIDEO/**", "$AUDIO/**"]
    }
  }
}
