{
  "$schema": "../node_modules/@tauri-apps/cli/schema/acl/capability.json",
  "identifier": "default",
  "description": "Default capability for Picasa Next desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:read-all",
    "fs:write-all",
    "fs:allow-read-dir",
    "shell:default",
    "shell:allow-open",
    "window-state:default"
  ]
}
